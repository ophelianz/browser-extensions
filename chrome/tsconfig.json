{
    "extends": "./.wxt/tsconfig.json",
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["chrome"],
        "paths": {
            "~/*": ["./src/*"],
            "@@/*": ["./*"],
            "@/*": ["./src/*"],
        },
    },
    "include": [
        "src",
        ".wxt/wxt.d.ts",
        ".wxt/types",
        "wxt.config.ts",
        "tailwind.config.ts",
    ],
    "exclude": ["node_modules", ".output"],
}
